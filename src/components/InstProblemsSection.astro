---
interface Problem {
    icon: string;
    title: string;
    description: string;
}

const problems: Problem[] = [
    {
        icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z",
        title: "Imagem Amadora",
        description: "Vídeos de baixa qualidade transmitem desprofissionalismo e afastam clientes antes mesmo de você abrir a boca."
    },
    {
        icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
        title: "Sem Conexão Emocional",
        description: "Conteúdo técnico e sem storytelling não cria vínculo com o público e é esquecido em segundos."
    },
    {
        icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
        title: "Oportunidades Perdidas",
        description: "Sem um vídeo institucional de qualidade, você perde a chance de apresentar sua empresa 24h por dia e gerar leads continuamente."
    }
];
---

<section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-gray-800 mb-4">
            Sua empresa é ótima, mas o vídeo não passa essa impressão?
        </h2>
        <p class="max-w-3xl mx-auto text-gray-600 mb-12 font-medium">
            O primeiro contato do seu cliente com a sua marca muitas vezes é através de um vídeo. Uma produção amadora pode custar clientes antes mesmo de você apresentar sua proposta.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            {problems.map((problem) => (
                <div class="space-y-4">
                    <div class="bg-red-100 p-4 rounded-lg inline-block">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={problem.icon} />
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800">{problem.title}</h3>
                    <p class="text-gray-600">{problem.description}</p>
                </div>
            ))}
        </div>
    </div>
</section>
