---
import { Image } from "astro:assets";
import logo from "../icons/wordmark.svg";

interface Props {
    title: string;
    description: string;
    ctaText: string;
    ctaLink: string;
    showLogo?: boolean;
}

const { title, description, ctaText, ctaLink, showLogo = true } = Astro.props;
---

<header id="top" class="hero-background text-white">
    <div class="container mx-auto px-6 py-24 text-center">
        {showLogo && (
            <div class="mb-8">
                <Image src={logo} alt="Logo da Nitro Produtora" class="mx-auto h-12" />
            </div>
        )}
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-tight mb-6">{title}</h1>
        <p class="text-lg md:text-xl text-purple-200 max-w-3xl mx-auto mb-10 font-medium">{description}</p>
        <a href={ctaLink} class="btn-cta text-lg px-10 py-4">{ctaText}</a>
    </div>
</header>

<style>
    .hero-background {
        background-color: #581c87;
        background-image: linear-gradient(135deg, #581c87d9 0%, #4c1d95f2 60%, #1e1b4bf2 100%);
        background-size: cover;
        background-position: center;
        padding-top: 5rem;
    }
</style>
