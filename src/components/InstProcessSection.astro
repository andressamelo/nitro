---
interface Step {
    number: number;
    title: string;
    description: string;
}

const steps: Step[] = [
    {
        number: 1,
        title: "Briefing",
        description: "Mergulhamos na sua marca: valores, missão, público-alvo e o que você quer comunicar."
    },
    {
        number: 2,
        title: "Roteiro & Storyboard",
        description: "Criamos o roteiro e planejamos cada cena para contar sua história com emoção e clareza."
    },
    {
        number: 3,
        title: "Gravação Profissional",
        description: "Captação em locação ou estúdio com equipe completa: câmeras, iluminação e som cinema."
    },
    {
        number: 4,
        title: "Pós-Produção",
        description: "Edição cinematográfica, colorização, trilha sonora licenciada e motion graphics com sua identidade visual."
    },
    {
        number: 5,
        title: "Entrega",
        description: "Arquivos em alta qualidade otimizados para site, redes sociais, apresentações e eventos."
    }
];
---

<section id="processo" class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-gray-800 mb-4">
            Do Briefing à Entrega: Nosso Processo
        </h2>
        <p class="max-w-3xl mx-auto text-gray-600 mb-12 font-medium">
            Cada projeto é único. Por isso, trabalhamos de forma estruturada para garantir que o resultado final represente sua empresa da melhor forma possível.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6 text-left relative">
            <div class="hidden md:block absolute top-[52px] left-0 w-full h-0.5 bg-gray-200" style="z-index: 0;"></div>
            {steps.map((step) => (
                <div class="bg-white p-6 rounded-lg shadow-lg z-10">
                    <div class="flex flex-col items-start gap-3 mb-3">
                        <div class="custom-purple-bg text-white rounded-full h-12 w-12 flex items-center justify-center font-bold text-lg shrink-0">
                            {step.number}
                        </div>
                        <h3 class="text-lg font-bold text-gray-800">{step.title}</h3>
                    </div>
                    <p class="text-gray-600 text-sm">{step.description}</p>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .custom-purple-bg {
        background-color: #581c87;
    }
</style>
