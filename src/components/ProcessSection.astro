---
interface Step {
    number: number;
    title: string;
    description: string;
}

const steps: Step[] = [
    {
        number: 1,
        title: "Planejamento",
        description: "Entendemos seus objetivos, o perfil dos seus alunos e definimos a estrutura das aulas."
    },
    {
        number: 2,
        title: "Gravação",
        description: "Cuidamos de tudo: iluminação, câmeras e som. Você só se preocupa com o conteúdo."
    },
    {
        number: 3,
        title: "Pós-Produção",
        description: "Editamos, adicionamos sua identidade visual, tratamos as cores e o áudio para um resultado impecável."
    },
    {
        number: 4,
        title: "Entrega",
        description: "Entregamos os arquivos prontos para você subir na sua plataforma e começar a vender."
    }
];
---

<section id="demonstracao" class="py-16 md:py-24 bg-offset">
    <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-default mb-4" data-animate>
            Nosso Processo Simplificado para Criar seu Curso
        </h2>
        <p class="max-w-3xl mx-auto text-offset mb-12 font-medium" data-animate>
            Do planejamento à entrega, cuidamos de cada detalhe para que você só precise focar no seu conteúdo.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-left relative" data-animate-stagger>
            <div class="hidden md:block absolute top-[52px] left-0 w-full h-px bg-border" style="z-index: 0;"></div>
            {steps.map((step) => (
                <div class="bg-default border border-default p-6 rounded-2xl shadow-sm z-10 transition-all duration-300 hover:-translate-y-1">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="bg-primary text-purple-900 rounded-full h-12 w-12 flex items-center justify-center font-bold text-lg shrink-0">
                            {step.number}
                        </div>
                        <h3 class="text-xl font-bold text-default">{step.title}</h3>
                    </div>
                    <p class="text-offset leading-relaxed">{step.description}</p>
                </div>
            ))}
        </div>
    </div>
</section>
