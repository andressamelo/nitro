---
import { Icon } from "astro-icon/components";
---

<section id="sites" class="scroll-mt-24 w-full">
  <div class="relative overflow-hidden rounded-2xl border border-purple-700/60 bg-gradient-to-br from-purple-950 via-purple-900 to-indigo-950 px-8 py-12 md:px-14 md:py-16 shadow-2xl">

    <div class="pointer-events-none absolute inset-0 opacity-10">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    <div class="relative flex flex-col gap-10 md:flex-row md:items-center">

      <div class="flex-1 space-y-6">
        <span class="inline-block rounded-full bg-yellow-400 px-4 py-1 text-xs font-bold uppercase tracking-widest text-purple-900">
          Nova área
        </span>

        <h2 class="text-3xl font-extrabold leading-tight tracking-tight text-white md:text-4xl">
          Seu vídeo merece um site<br class="hidden md:block" />
          <span class="text-yellow-400"> à altura</span>
        </h2>

        <p class="max-w-lg text-base leading-relaxed text-gray-300 md:text-lg">
          Agora a Nitro também cria <strong class="text-white">sites e landing pages profissionais</strong>.
          O vídeo conecta, o site converte — e nós fazemos os dois.
        </p>

        <a
          href="/websites"
          class="inline-flex items-center gap-2 rounded-full bg-yellow-400 px-7 py-3 font-bold text-purple-900 transition-all duration-300 hover:scale-105 hover:bg-yellow-300 hover:shadow-lg hover:shadow-yellow-400/30"
        >
          Conheça os Sites Nitro
          <Icon name="mdi:arrow-right" class="size-5" />
        </a>
      </div>

      <div class="grid grid-cols-2 gap-4 md:w-72 md:flex-shrink-0">
        {[
          { icon: "mdi:monitor-screenshot", label: "Landing Pages" },
          { icon: "mdi:domain", label: "Sites Institucionais" },
          { icon: "mdi:school-outline", label: "Sites para Cursos" },
          { icon: "mdi:palette-outline", label: "Portfólios Digitais" },
        ].map(({ icon, label }) => (
          <div class="flex flex-col items-center gap-3 rounded-xl border border-white/10 bg-white/5 p-5 text-center backdrop-blur-sm transition-colors hover:bg-white/10">
            <Icon name={icon} class="size-8 text-yellow-400" />
            <span class="text-xs font-semibold leading-tight text-gray-200">{label}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
