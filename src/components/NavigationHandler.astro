---
interface Props {
    triggerSection?: string;
}
const { triggerSection = "#demonstracao" } = Astro.props;
---

<script define:vars={{ triggerSection }}>
    const header = document.querySelector("#page-header");
    const trigger = document.querySelector(triggerSection);
    const navItems = header?.querySelector("nav");
    const logo = header?.querySelector("a:first-child");

    // Initially hide nav items and logo
    [navItems, logo].forEach(element => {
        if (element) {
            element.classList.add("opacity-0", "pointer-events-none");
        }
    });

    window.addEventListener("scroll", () => {
        if (trigger && navItems && logo) {
            const rect = trigger.getBoundingClientRect();
            if (rect.top <= 0) {
                [navItems, logo].forEach(element => {
                    element.classList.remove("opacity-0", "pointer-events-none");
                    element.classList.add("opacity-100");
                });
            } else {
                [navItems, logo].forEach(element => {
                    element.classList.remove("opacity-100");
                    element.classList.add("opacity-0", "pointer-events-none");
                });
            }
        }
    });
</script>